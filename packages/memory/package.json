{
  "name": "@agentforge/memory",
  "version": "0.1.0",
  "type": "module",
  "description": "Memory management for AgentForge",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentforge/core": "workspace:*",
    "effect": "4.0.0-beta.43",
    "gpt-3-encoder": "^1.1.4"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.8"
  }
}

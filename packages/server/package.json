{
  "name": "@primo512109/agentforge-server",
  "version": "0.1.0",
  "description": "HTTP/SSE server for AgentForge Studio",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },

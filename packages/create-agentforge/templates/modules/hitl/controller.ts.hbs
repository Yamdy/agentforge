/**
 * Human-in-the-loop controller for {{config.agentName}}.
 * Provides terminal-based approval interface.
 */

import type { HITLController, HITLAskOptions } from 'agentforge';
import { Observable } from 'rxjs';
import * as readline from 'node:readline';

/**
 * Default HITL controller implementation.
 * Prompts for approval via terminal.
 */
export class DefaultHITLController implements HITLController {
  private rl: readline.Interface | null = null;
  
  private getReadline(): readline.Interface {
    if (!this.rl) {
      this.rl = readline.createInterface({
        input: process.stdin,
        output: process.stdout,
      });
    }
    return this.rl;
  }
  
  /**
   * Ask for human approval
   */
  ask(options: HITLAskOptions): Observable<string> {
    return new Observable(subscriber => {
      const rl = this.getReadline();
      
      console.log('\n\x1b[33m[HITL] Approval Required\x1b[0m');
      console.log(`Type: ${options.type}`);
      
      if (options.message) {
        console.log(`Message: ${options.message}`);
      }
      
      if (options.data) {
        console.log('Data:', JSON.stringify(options.data, null, 2));
      }
      
      const question = options.question ?? 'Do you approve? (y/n)';
      
      rl.question(`\x1b[33m[HITL] ${question}: \x1b[0m`, (answer) => {
        const trimmed = answer.trim().toLowerCase();
        
        if (trimmed === 'y' || trimmed === 'yes') {
          subscriber.next('approved');
        } else if (trimmed === 'n' || trimmed === 'no') {
          subscriber.next('rejected');
        } else {
          // Custom response
          subscriber.next(answer.trim());
        }
        
        subscriber.complete();
      });
    });
  }
  
  /**
   * Called when the agent pauses for human input
   */
  async onAgentPause(agentId: string, reason?: string): Promise<void> {
    console.log(`\n\x1b[33m[HITL] Agent ${agentId} paused\x1b[0m`);
    if (reason) {
      console.log(`Reason: ${reason}`);
    }
  }
  
  /**
   * Called when the agent resumes after human input
   */
  async onAgentResume(agentId: string, _input?: string): Promise<void> {
    console.log(`\x1b[33m[HITL] Agent ${agentId} resumed\x1b[0m`);
  }
  
  /**
   * Close the readline interface
   */
  close(): void {
    if (this.rl) {
      this.rl.close();
      this.rl = null;
    }
  }
}

// Export singleton instance
export const hitlController = new DefaultHITLController();

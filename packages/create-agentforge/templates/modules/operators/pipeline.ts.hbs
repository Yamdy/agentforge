/**
 * Hook-based pipeline for {{config.agentName}}.
 * Uses AgentForge Hook system for event processing.
 */

import type { AgentEvent } from 'agentforge';
import {
  applyPlugins,
  HookRegistry,
  AgentEventEmitter,
} from 'agentforge';

export interface PipelineOptions {
  /** Enable console logging */
  logging?: boolean;
  /** Enable metrics collection */
  metrics?: boolean;
  /** Timeout in milliseconds */
  timeout?: number;
  /** Retry count on errors */
  retries?: number;
}

/**
 * Build a pipeline of operators for event stream processing.
 * This is an example of composing multiple operators.
 */
export function buildPipeline(options: PipelineOptions = {}): OperatorFunction<AgentEvent, AgentEvent>[] {
  const operators: OperatorFunction<AgentEvent, AgentEvent>[] = [];
  
  // 1. Logging (if enabled)
  if (options.logging) {
    operators.push(
      tap(event => {
        const colorMap: Record<string, string> = {
          'agent.': '\x1b[36m', // cyan
          'llm.': '\x1b[34m',   // blue
          'tool.': '\x1b[32m',  // green
          'hitl.': '\x1b[33m',  // yellow
          'agent.error': '\x1b[31m', // red
          'done': '\x1b[90m',   // gray
        };
        
        for (const [prefix, color] of Object.entries(colorMap)) {
          if (event.type.startsWith(prefix) || event.type === prefix) {
            console.log(`${color}[${event.type}]\x1b[0m`, event);
            break;
          }
        }
      })
    );
  }
  
  // 2. Metrics collection (if enabled)
  if (options.metrics) {
    operators.push(
      collectMetrics(metrics => {
        console.log('\x1b[34m[Metrics]\x1b[0m', metrics);
      })
    );
  }
  
  // 3. Timeout handling (if specified)
  if (options.timeout) {
    operators.push(
      timeoutOnEventType('done', options.timeout)
    );
  }
  
  // 4. Error retry (if specified)
  if (options.retries) {
    operators.push(
      retryOnEventType('agent.error', options.retries)
    );
  }
  
  // 5. Always terminate on done
  operators.push(takeUntilTerminal());
  
  return operators;
}

/**
 * Default pipeline configuration.
 */
export const defaultPipelineOptions: PipelineOptions = {
  logging: true,
  metrics: true,
  timeout: 60000,
  retries: 2,
};

/**
 * Create a pipeline with default options.
 */
export function createDefaultPipeline(): OperatorFunction<AgentEvent, AgentEvent>[] {
  return buildPipeline(defaultPipelineOptions);
}

/**
 * Create a production-optimized pipeline.
 */
export function createProductionPipeline(): OperatorFunction<AgentEvent, AgentEvent>[] {
  return buildPipeline({
    logging: false,
    metrics: true,
    timeout: 30000,
    retries: 3,
  });
}

/**
 * Create a debug pipeline with verbose output.
 */
export function createDebugPipeline(): OperatorFunction<AgentEvent, AgentEvent>[] {
  return buildPipeline({
    logging: true,
    metrics: true,
    timeout: 300000, // 5 minutes
    retries: 0, // No auto-retry for debugging
  });
}

/**
 * Console metrics collector for {{config.agentName}}.
 * Tracks and reports agent execution metrics.
 */

import type { AgentEvent } from 'agentforge';

export interface MetricValue {
  name: string;
  value: number;
  timestamp: number;
  tags?: Record<string, string>;
}

export interface MetricSummary {
  [key: string]: {
    count: number;
    sum: number;
    min: number;
    max: number;
    avg: number;
  };
}

/**
 * Console-based metrics implementation
 */
export class ConsoleMetrics {
  private counters: Map<string, number> = new Map();
  private gauges: Map<string, number> = new Map();
  private histograms: Map<string, number[]> = new Map();
  private eventCounts: Map<string, number> = new Map();
  
  // === Counter operations ===
  
  increment(name: string, value: number = 1, _tags?: Record<string, string>): void {
    const current = this.counters.get(name) ?? 0;
    this.counters.set(name, current + value);
  }
  
  decrement(name: string, value: number = 1, _tags?: Record<string, string>): void {
    const current = this.counters.get(name) ?? 0;
    this.counters.set(name, current - value);
  }
  
  // === Gauge operations ===
  
  gauge(name: string, value: number, _tags?: Record<string, string>): void {
    this.gauges.set(name, value);
  }
  
  // === Histogram operations ===
  
  histogram(name: string, value: number, _tags?: Record<string, string>): void {
    const values = this.histograms.get(name) ?? [];
    values.push(value);
    this.histograms.set(name, values);
  }
  
  // === Timing ===
  
  timing(name: string, durationMs: number, _tags?: Record<string, string>): void {
    this.histogram(name, durationMs);
    console.log(`\x1b[34m[METRIC]\x1b[0m ${name}: ${durationMs.toFixed(2)}ms`);
  }
  
  // === Event tracking ===
  
  trackEvent(event: AgentEvent): void {
    const count = this.eventCounts.get(event.type) ?? 0;
    this.eventCounts.set(event.type, count + 1);
    
    // Track specific metrics
    if (event.type === 'agent.step') {
      this.increment('agent.steps');
    } else if (event.type === 'llm.response') {
      this.increment('llm.calls');
      if ('usage' in event && event.usage) {
        const usage = event.usage as { promptTokens?: number; completionTokens?: number };
        if (usage.promptTokens) this.histogram('tokens.prompt', usage.promptTokens);
        if (usage.completionTokens) this.histogram('tokens.completion', usage.completionTokens);
      }
    } else if (event.type === 'tool.result') {
      this.increment('tools.executed');
    }
  }
  
  // === Getters ===
  
  getCounter(name: string): number {
    return this.counters.get(name) ?? 0;
  }
  
  getGauge(name: string): number | undefined {
    return this.gauges.get(name);
  }
  
  getHistogram(name: string): number[] {
    return this.histograms.get(name) ?? [];
  }
  
  getEventCounts(): Map<string, number> {
    return new Map(this.eventCounts);
  }
  
  // === Summary ===
  
  getSummary(): MetricSummary {
    const summary: MetricSummary = {};
    
    // Add counters
    for (const [name, value] of this.counters) {
      summary[name] = {
        count: 1,
        sum: value,
        min: value,
        max: value,
        avg: value,
      };
    }
    
    // Add gauges
    for (const [name, value] of this.gauges) {
      summary[name] = {
        count: 1,
        sum: value,
        min: value,
        max: value,
        avg: value,
      };
    }
    
    // Add histograms with statistics
    for (const [name, values] of this.histograms) {
      if (values.length > 0) {
        const sum = values.reduce((a, b) => a + b, 0);
        summary[name] = {
          count: values.length,
          sum,
          min: Math.min(...values),
          max: Math.max(...values),
          avg: sum / values.length,
        };
      }
    }
    
    return summary;
  }
  
  printSummary(): void {
    const summary = this.getSummary();
    console.log('\n\x1b[34m=== Metrics Summary ===\x1b[0m');
    
    for (const [name, stats] of Object.entries(summary)) {
      console.log(`  ${name}: count=${stats.count}, avg=${stats.avg.toFixed(2)}, min=${stats.min}, max=${stats.max}`);
    }
    
    // Print event counts
    console.log('\n\x1b[34m=== Event Counts ===\x1b[0m');
    for (const [eventType, count] of this.eventCounts) {
      console.log(`  ${eventType}: ${count}`);
    }
  }
}

// Export singleton instance
export const metrics = new ConsoleMetrics();

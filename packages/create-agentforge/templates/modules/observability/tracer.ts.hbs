/**
 * Console tracer for {{config.agentName}}.
 * Tracks execution spans and timing.
 */

import type { AgentEvent } from 'agentforge';

export interface Span {
  id: string;
  name: string;
  startTime: number;
  endTime?: number;
  duration?: number;
  parentSpanId?: string;
  events: AgentEvent[];
}

/**
 * Console-based tracer implementation
 */
export class ConsoleTracer {
  private spans: Map<string, Span> = new Map();
  private currentSpanId: string | null = null;
  
  startSpan(name: string, parentSpanId?: string): string {
    const id = `span-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    
    const span: Span = {
      id,
      name,
      startTime: performance.now(),
      parentSpanId,
      events: [],
    };
    
    this.spans.set(id, span);
    this.currentSpanId = id;
    
    console.log(`\x1b[35m[TRACE]\x1b[0m Started span: ${name} (${id})`);
    
    return id;
  }
  
  endSpan(spanId: string): void {
    const span = this.spans.get(spanId);
    if (!span) return;
    
    span.endTime = performance.now();
    span.duration = span.endTime - span.startTime;
    
    const duration = span.duration.toFixed(2);
    console.log(`\x1b[35m[TRACE]\x1b[0m Ended span: ${span.name} (${spanId}) - ${duration}ms`);
    
    if (this.currentSpanId === spanId) {
      this.currentSpanId = span.parentSpanId ?? null;
    }
  }
  
  addEvent(event: AgentEvent): void {
    if (this.currentSpanId) {
      const span = this.spans.get(this.currentSpanId);
      if (span) {
        span.events.push(event);
      }
    }
  }
  
  getSpan(spanId: string): Span | undefined {
    return this.spans.get(spanId);
  }
  
  getAllSpans(): Span[] {
    return Array.from(this.spans.values());
  }
  
  getRootSpans(): Span[] {
    return Array.from(this.spans.values()).filter(s => !s.parentSpanId);
  }
  
  printSummary(): void {
    const spans = this.getAllSpans();
    console.log('\n\x1b[35m=== Trace Summary ===\x1b[0m');
    
    for (const span of spans) {
      const duration = span.duration?.toFixed(2) ?? 'ongoing';
      const eventCount = span.events.length;
      console.log(`  ${span.name}: ${duration}ms (${eventCount} events)`);
    }
  }
}

// Export singleton instance
export const tracer = new ConsoleTracer();

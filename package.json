{
  "name": "agentforge-root",
  "private": true,
  "version": "0.1.0",
  "description": "TypeScript framework for building AI applications, agents, and workflows",
  "packageManager": "pnpm@10.18.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "dev:server": "pnpm -F @agentforge/server dev",
    "start:server": "pnpm -F @agentforge/server start",
    "deploy": "sst deploy",
    "deploy:staging": "sst deploy --stage staging",
    "deploy:production": "sst deploy --stage production",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages/**/*.ts",
    "lint:fix": "eslint packages/**/*.ts --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "llm": "pnpm -F @agentforge/llm cli"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "ai": "6.0.149",
    "effect": "4.0.0-beta.43",
    "gpt-3-encoder": "^1.1.4",
    "remeda": "2.26.0",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.0.0"
  }
}

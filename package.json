{
  "name": "agentforge",
  "version": "0.1.0",
  "description": "TypeScript framework for building AI applications, agents, and workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentforge": "./dist/cli/index.js"
  },
  "keywords": [
    "ai",
    "agent",
    "framework",
    "typescript",
    "llm",
    "workflow",
    "mcp"
  ],
  "author": "AgentForge Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/agentforge"
  },
  "homepage": "https://github.com/your-org/agentforge",
  "bugs": {
    "url": "https://github.com/your-org/agentforge/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "demo": "tsx src/examples/demo.ts",
    "demo:server": "tsx src/examples/demo.ts server",
    "demo:client": "tsx src/examples/demo.ts client",
    "test:e2e": "vitest run tests/e2e.test.ts",
    "test:e2e:watch": "vitest tests/e2e.test.ts",
    "demo:e2e": "tsx src/examples/demo.ts e2e",
    "demo:web": "tsx src/examples/demo.ts web",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@agents-mdx/runtime": "0.0.15",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/openai-compatible": "^2.0.38",
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@primno/dpapi": "^2.0.1",
    "ai": "^6.0.146",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "dotenv": "^17.4.1",
    "execa": "^8.0.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.10",
    "hono-zod": "^1.1.1",
    "inquirer": "^9.2.0",
    "mathjs": "^15.2.0",
    "minimatch": "^10.2.5",
    "openapi-types": "^12.1.3",
    "picocolors": "^1.1.1",
    "rxjs": "^7.8.2",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "1.6.1",
    "eslint": "^9.0.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^1.0.0"
  }
}

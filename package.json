{
  "name": "primo-agent",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "primo-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "demo": "tsx src/examples/demo.ts",
    "demo:server": "tsx src/examples/demo.ts server",
    "demo:client": "tsx src/examples/demo.ts client",
    "test:e2e": "vitest run tests/e2e.test.ts",
    "test:e2e:watch": "vitest tests/e2e.test.ts",
    "demo:e2e": "tsx src/examples/demo.ts e2e",
    "demo:web": "tsx src/examples/demo.ts web",
    "test": "vitest",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@agents-mdx/runtime": "0.0.15",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/openai-compatible": "^2.0.38",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "ai": "^6.0.146",
    "commander": "^12.0.0",
    "dotenv": "^17.4.1",
    "hono": "^4.12.10",
    "hono-zod": "^1.1.1",
    "inquirer": "^9.2.0",
    "openapi-types": "^12.1.3",
    "rxjs": "^7.8.2",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}

{
  "name": "@primo512109/agentforge",
  "version": "0.1.3-alpha.20260429",
  "description": "Production-ready Agent framework with MPU (Minimum Production Usable) modules - event-driven architecture + Zod type safety",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentforge": "dist/cli/index.js",
    "create-agentforge": "scripts/create-agent.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./planning": {
      "types": "./dist/planning/index.d.ts",
      "import": "./dist/planning/index.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox/index.d.ts",
      "import": "./dist/sandbox/index.js"
    },
    "./resilience": {
      "types": "./dist/resilience/index.d.ts",
      "import": "./dist/resilience/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js"
    },
    "./quota": {
      "types": "./dist/quota/index.d.ts",
      "import": "./dist/quota/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle/index.d.ts",
      "import": "./dist/lifecycle/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js"
    },
    "./integration": {
      "types": "./dist/integration/index.d.ts",
      "import": "./dist/integration/index.js"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "import": "./dist/app/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    },
    "./skill": {
      "types": "./dist/skill/index.d.ts",
      "import": "./dist/skill/index.js"
    },
    "./a2a": {
      "types": "./dist/a2a/index.d.ts",
      "import": "./dist/a2a/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./subagent": {
      "types": "./dist/subagent/index.d.ts",
      "import": "./dist/subagent/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    },
    "./quickstart": {
      "types": "./dist/quickstart.d.ts",
      "import": "./dist/quickstart.js"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e --reporter=verbose",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "agent",
    "llm",
    "zod",
    "ai",
    "framework",
    "mpu",
    "production-ready",
    "sandbox",
    "audit",
    "security",
    "observability"
  ],
  "author": "primo512109",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yamdy/agentforge.git"
  },
  "bugs": {
    "url": "https://github.com/Yamdy/agentforge/issues"
  },
  "homepage": "https://github.com/Yamdy/agentforge#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.168",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "inquirer": "^10.0.0",
    "js-tiktoken": "^1.0.21",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@types/better-sqlite3": "^7.6.13",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^1.6.1",
    "ai-sdk-ollama": "^1.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.7",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vitepress": "^1.6.4",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ],
    "examples/**/*.ts": [
      "prettier --write"
    ]
  }
}
